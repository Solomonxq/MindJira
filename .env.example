# ==========================================
# Infrastructure (Docker Compose)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ==========================================
# Auth Service
# ==========================================
AUTH_PROJECT_NAME=auth
AUTH_ENV=development
AUTH_DEBUG=True
AUTH_SECRET_KEY=your-secret-key-here
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/db_name
AUTH_REDIS_URL=redis://redis:6379/0
AUTH_INTERNAL_SERVICE_TOKEN=your-internal-token

# ==========================================
# Gateway Service
# ==========================================
GATEWAY_PROJECT_NAME=gateway
GATEWAY_ENV=development
GATEWAY_DEBUG=True
GATEWAY_DB_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/db_name
GATEWAY_REDIS_URL=redis://redis:6379/0

# ==========================================
# Sprint Summary Service
# ==========================================
SPRINT_PROJECT_NAME=sprint-summary
SPRINT_ENV=development
SPRINT_DEBUG=True
SPRINT_REDIS_URL=redis://redis:6379/0
SPRINT_JIRA_API_TOKEN=your-jira-api-token

# ==========================================
# Description Enricher Service
# ==========================================
Deskrip_PROJECT_NAME=description-enricher
Deskrip_ENV=development
Deskrip_DEBUG=True

# ==========================================
# Test Case Generator Service
# ==========================================
# NOTE: uses same prefix as description-enricher (Deskrip_)
Deskrip_PROJECT_NAME=test-case-generator
Deskrip_ENV=development
Deskrip_DEBUG=True

# ==========================================
# JWT (used by auth or gateway)
# ==========================================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
