# ==========================================
# Infrastructure (Docker Compose)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ==========================================
# Auth Service
# ==========================================
AUTH_PROJECT_NAME=auth
AUTH_ENV=development
AUTH_DEBUG=True
AUTH_SECRET_KEY=your-secret-key-here
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/db_name
AUTH_REDIS_URL=redis://redis:6379/0
AUTH_INTERNAL_SERVICE_TOKEN=your-internal-token

# ==========================================
# Gateway Service
# ==========================================
GATEWAY_PROJECT_NAME=gateway
GATEWAY_ENV=development
GATEWAY_DEBUG=True
GATEWAY_DB_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/db_name
GATEWAY_REDIS_URL=redis://redis:6379/0
GATEWAY_INTERNAL_SERVICE_TOKEN=your-internal-token
GATEWAY_AUTH_SERVICE_URL=http://traefik/auth
GATEWAY_SPRINT_SUMMARY_SERVICE_URL=http://traefik/sprint-summary

# ==========================================
# Sprint Summary Service
# ==========================================
SPRINT_PROJECT_NAME=sprint-summary
SPRINT_ENV=development
SPRINT_DEBUG=True
SPRINT_REDIS_URL=redis://redis:6379/0
SPRINT_JIRA_API_TOKEN=your-jira-api-token

# ==========================================
# Description Enricher Service
# ==========================================
Deskrip_PROJECT_NAME=description-enricher
Deskrip_ENV=development
Deskrip_DEBUG=True
Deskrip_DB_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/description_enricher_db
Deskrip_REDIS_URL=redis://redis:6379/0
Deskrip_JIRA_API_TOKEN=your-jira-api-token
Deskrip_JIRA_BASE_URL=https://your-domain.atlassian.net
Deskrip_JIRA_EMAIL=your-email@example.com
Deskrip_AI_API_KEY=your-nvidia-api-key
Deskrip_AI_MODEL=meta/llama-3.1-70b-instruct
Deskrip_AI_BASE_URL=https://integrate.api.nvidia.com/v1
Deskrip_DESCRIPTION_LANGUAGE=uk
Deskrip_AUTO_APPLY_TO_JIRA=True

# ==========================================
# Test Case Generator Service
# ==========================================
TEST_CASE_GENERATOR_PROJECT_NAME=test-case-generator
TEST_CASE_GENERATOR_ENV=development
TEST_CASE_GENERATOR_DEBUG=True
TEST_CASE_GENERATOR_DB_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/test_case_generator_db
TEST_CASE_GENERATOR_REDIS_URL=redis://redis:6379/0

# ==========================================
# JWT (used by auth or gateway)
# ==========================================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
