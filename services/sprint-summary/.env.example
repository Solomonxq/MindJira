# Environment variables for sprint-summary service
# The service uses env prefix `SPRINT_` by default (change SERVICE_ENV_PREFIX to override).

# Basic
SPRINT_PROJECT_NAME=sprint-summary
SPRINT_ENV=production
SPRINT_DEBUG=false

# Database (asyncpg URI used by SQLAlchemy async engine)
SPRINT_DB_URL=postgresql+asyncpg://dbuser:dbpass@localhost:5432/sprint_summary_db

# Redis (used for caching Jira responses)
SPRINT_REDIS_URL=redis://localhost:6379/0

# JIRA
SPRINT_JIRA_API_TOKEN=your_jira_api_token_here
SPRINT_JIRA_BASE_URL=https://your-domain.atlassian.net
SPRINT_JIRA_EMAIL=service-account@yourcompany.com

# AI provider (Anthropic by default; can be OpenAI if configured in ai-client)
SPRINT_AI_API_KEY=your_ai_api_key_here
SPRINT_AI_MODEL=claude-3.5-sonnet

# Optional integrations
# Slack incoming webhook to post generated reports
SPRINT_SLACK_WEBHOOK=our_slack_webhook_here

# Confluence (optional) - example base URL; needs user + API token
SPRINT_CONFLUENCE_API_URL=https://your-domain.atlassian.net/wiki
SPRINT_CONFLUENCE_USER=confluence-user@yourcompany.com
SPRINT_CONFLUENCE_TOKEN=your_confluence_api_token

# Notes:
# - Keep secrets out of source control; store in CI/CD secret store or vault.
# - If you use a different env prefix, set SERVICE_ENV_PREFIX accordingly.
